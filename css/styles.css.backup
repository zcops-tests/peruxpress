/* ===========================================
   PURE CSS STYLES
   ===========================================
   Custom CSS for Perú Xpress Inmobiliaria website
   No framework dependencies
   =========================================== */

/* ===========================================
   CSS CUSTOM PROPERTIES (COLOR PALETTE)
   =========================================== */

:root {
    /* Brand Colors */
    --charcoal: #0f1115;
    --surface: #171b22;
    --electric-blue: #2e90fa;
    --vibrant-teal: #15e1d0;
    --metallic-silver: #94a3b8;
    --text-main: #f8fafc;
    --text-muted: #64748b;
    --deep-navy: #0a0c10;

    /* Utility Colors */
    --white: #ffffff;
    --black: #000000;
    --transparent: transparent;

    /* Opacity Variants */
    --black-30: rgba(0, 0, 0, 0.3);
    --black-40: rgba(0, 0, 0, 0.4);
    --black-50: rgba(0, 0, 0, 0.5);
    --black-60: rgba(0, 0, 0, 0.6);
    --black-80: rgba(0, 0, 0, 0.8);
    --black-90: rgba(0, 0, 0, 0.9);
    --white-5: rgba(255, 255, 255, 0.05);
    --white-10: rgba(255, 255, 255, 0.1);
    --white-20: rgba(255, 255, 255, 0.2);
    --white-50: rgba(255, 255, 255, 0.5);
    --white-90: rgba(255, 255, 255, 0.9);

    /* Specific Colors */
    --purple-400: #c084fc;
    --purple-500: #a855f7;
    --cyan-400: #22d3ee;
    --cyan-500: #06b6d4;
    --blue-500: #3b82f6;
    --blue-600: #2563eb;
    --green-500: #10b981;
    --red-500: #ef4444;
    --yellow-500: #eab308;
    --gray-500: #6b7280;
    --gray-900: #111827;

    /* Ring and Shadow Colors */
    --ring-blue: rgba(59, 130, 246, 0.5);
    --shadow-blue-20: rgba(59, 130, 246, 0.2);
    --shadow-blue-40: rgba(59, 130, 246, 0.4);
    --shadow-purple-10: rgba(168, 85, 247, 0.1);
    --shadow-purple-500: rgba(168, 85, 247, 0.5);
    --shadow-teal: rgba(21, 225, 208, 0.1);
    --shadow-white-5: rgba(255, 255, 255, 0.05);
}

/* ===========================================
   BASE RESET STYLES
   =========================================== */

* {
    box-sizing: border-box;
}

:host,
html {
    line-height: 1.5;
    -webkit-text-size-adjust: 100%;
    -moz-tab-size: 4;
    -o-tab-size: 4;
    tab-size: 4;
    font-family: Inter, sans-serif;
    font-feature-settings: normal;
    font-variation-settings: normal;
    -webkit-tap-highlight-color: transparent;
}

body {
    margin: 0;
    line-height: inherit;
    background-color: var(--charcoal);
    color: var(--text-main);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

hr {
    height: 0;
    color: inherit;
    border-top-width: 1px;
}

abbr:where([title]) {
    -webkit-text-decoration: underline dotted;
    text-decoration: underline dotted;
}

h1,
h2,
h3,
h4,
h5,
h6 {
    font-size: inherit;
    font-weight: inherit;
}

a {
    color: inherit;
    text-decoration: inherit;
}

b,
strong {
    font-weight: bolder;
}

code,
kbd,
pre,
samp {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, Courier New, monospace;
    font-feature-settings: normal;
    font-variation-settings: normal;
    font-size: 1em;
}

small {
    font-size: 80%;
}

sub,
sup {
    font-size: 75%;
    line-height: 0;
    position: relative;
    vertical-align: baseline;
}

sub {
    bottom: -0.25em;
}

sup {
    top: -0.5em;
}

table {
    text-indent: 0;
    border-color: inherit;
    border-collapse: collapse
}

button,
input,
optgroup,
select,
textarea {
    font-family: inherit;
    font-feature-settings: inherit;
    font-variation-settings: inherit;
    font-size: 100%;
    font-weight: inherit;
    line-height: inherit;
    letter-spacing: inherit;
    color: inherit;
    margin: 0;
    padding: 0
}

button,
select {
    text-transform: none
}

button,
input:where([type=button]),
input:where([type=reset]),
input:where([type=submit]) {
    -webkit-appearance: button;
    background-color: transparent;
    background-image: none
}

:-moz-focusring {
    outline: auto
}

:-moz-ui-invalid {
    box-shadow: none
}

progress {
    vertical-align: baseline
}

::-webkit-inner-spin-button,
::-webkit-outer-spin-button {
    height: auto
}

[type=search] {
    -webkit-appearance: textfield;
    outline-offset: -2px
}

::-webkit-search-decoration {
    -webkit-appearance: none
}

::-webkit-file-upload-button {
    -webkit-appearance: button;
    font: inherit
}

summary {
    display: list-item
}

blockquote,
dd,
dl,
figure,
h1,
h2,
h3,
h4,
h5,
h6,
hr,
p,
pre {
    margin: 0
}

fieldset {
    margin: 0
}

fieldset,
legend {
    padding: 0
}

menu,
ol,
ul {
    list-style: none;
    margin: 0;
    padding: 0
}

dialog {
    padding: 0
}

textarea {
    resize: vertical
}

input::-moz-placeholder,
textarea::-moz-placeholder {
    opacity: 1;
    color: #9ca3af
}

input::placeholder,
textarea::placeholder {
    opacity: 1;
    color: #9ca3af
}

[role=button],
button {
    cursor: pointer
}

:disabled {
    cursor: default
}

audio,
canvas,
embed,
iframe,
img,
object,
svg,
video {
    display: block;
    vertical-align: middle
}

img,
video {
    max-width: 100%;
    height: auto
}

[hidden]:where(:not([hidden=until-found])) {
    display: none
}

.sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0
}

.pointer-events-none {
    pointer-events: none
}

/* ===========================================
   POSITIONING UTILITIES
   =========================================== */

.static {
    position: static
}

.fixed {
    position: fixed
}

.absolute {
    position: absolute
}

.relative {
    position: relative
}

.inset-0 {
    inset: 0
}

.inset-y-0 {
    top: 0;
    bottom: 0
}

.-left-64 {
    left: -16rem
}

.-right-2 {
    right: -.5rem
}

.-right-64 {
    right: -16rem
}

.-top-4 {
    top: -1rem
}

.bottom-0 {
    bottom: 0
}

.bottom-6 {
    bottom: 1.5rem
}

.left-0 {
    left: 0
}

.left-6 {
    left: 1.5rem
}

.left-\[12\.5\%\] {
    left: 12.5%
}

.left-\[37\.5\%\] {
    left: 37.5%
}

.left-\[62\.5\%\] {
    left: 62.5%
}

.left-\[87\.5\%\] {
    left: 87.5%
}

.right-0 {
    right: 0
}

.right-6 {
    right: 1.5rem
}

.top-0 {
    top: 0
}

.top-1\/4 {
    top: 25%
}

.top-\[-6px\] {
    top: -6px
}

.z-0 {
    z-index: 0
}

.z-10 {
    z-index: 10
}

.z-20 {
    z-index: 20
}

.z-50 {
    z-index: 50
}

.z-\[1000\] {
    z-index: 1000
}

.order-1 {
    order: 1
}

.order-2 {
    order: 2
}

/* ===========================================
   SPACING UTILITIES (MARGINS)
   =========================================== */

.mx-2 {
    margin-left: .5rem;
    margin-right: .5rem
}

.mx-auto {
    margin-left: auto;
    margin-right: auto
}

.mb-1 {
    margin-bottom: .25rem
}

.mb-10 {
    margin-bottom: 2.5rem
}

.mb-12 {
    margin-bottom: 3rem
}

.mb-16 {
    margin-bottom: 4rem
}

.mb-2 {
    margin-bottom: .5rem
}

.mb-3 {
    margin-bottom: .75rem
}

.mb-4 {
    margin-bottom: 1rem
}

.mb-6 {
    margin-bottom: 1.5rem
}

.mb-8 {
    margin-bottom: 2rem
}

.mt-0\.5 {
    margin-top: .125rem
}

.mt-1 {
    margin-top: .25rem
}

.mt-12 {
    margin-top: 3rem
}

.mt-16 {
    margin-top: 4rem
}

.mt-2 {
    margin-top: .5rem
}

.mt-4 {
    margin-top: 1rem
}

/* ===========================================
   DISPLAY & LAYOUT UTILITIES
   =========================================== */

.block {
    display: block
}

.flex {
    display: flex
}

.inline-flex {
    display: inline-flex
}

.grid {
    display: grid
}

.hidden {
    display: none
}

.aspect-\[4\/5\] {
    aspect-ratio: 4/5
}

.aspect-square {
    aspect-ratio: 1/1
}

/* ===========================================
   SIZING UTILITIES
   =========================================== */

.h-12 {
    height: 3rem
}

.h-14 {
    height: 3.5rem
}

.h-20 {
    height: 5rem
}

.h-3 {
    height: .75rem
}

.h-48 {
    height: 12rem
}

.h-6 {
    height: 1.5rem
}

.h-8 {
    height: 2rem
}

.h-\[30rem\] {
    height: 30rem
}

.h-full {
    height: 100%
}

.max-h-\[85vh\] {
    max-height: 85vh
}

.min-h-screen {
    min-height: 100vh
}

.w-1\/3 {
    width: 33.333333%
}

.w-14 {
    width: 3.5rem
}

.w-20 {
    width: 5rem
}

.w-3 {
    width: .75rem
}

.w-8 {
    width: 2rem
}

.w-\[1px\] {
    width: 1px
}

.w-\[30rem\] {
    width: 30rem
}

.w-full {
    width: 100%
}

.max-w-2xl {
    max-width: 42rem
}

/* ===========================================
   SEMANTIC COMPONENT CLASSES
   =========================================== */

/* container with responsive horizontal padding */
.container {
    max-width: 80rem;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
}
@media (min-width: 640px) {
    .container {
        padding-left: 2rem;
        padding-right: 2rem;
    }
}
@media (min-width: 1024px) {
    .container {
        padding-left: 3rem;
        padding-right: 3rem;
    }
}

/* navigation bar */
.navbar {
    position: fixed;
    width: 100%;
    z-index: 50;
    transition: all .3s;
    background-color: rgba(10, 12, 16, 0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}
.navbar .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 5rem; /* 20 */
}

.nav-link {
    font-size: .875rem;
    font-weight: 500;
    color: var(--metallic-silver);
    transition: color .2s, opacity .2s;
    cursor: pointer;
    text-decoration: none;
}
.nav-link:hover,
.nav-link:focus {
    color: #fff;
}

.nav-link.active {
    color: #fff;
    font-weight: 700;
    border-bottom: 2px solid var(--electric-blue);
    padding-bottom: .25rem;
}

.mobile-nav-link {
    display: block;
    padding: .5rem .75rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--metallic-silver);
    border-radius: .375rem;
    transition: color .2s, background-color .2s;
    cursor: pointer;
    text-decoration: none;
}
.mobile-nav-link:hover,
.mobile-nav-link:focus {
    color: #fff;
    background-color: rgba(255,255,255,.05);
}

.mobile-nav-link.active {
    color: #fff;
    font-weight: 700;
    background-color: rgba(255,255,255,.1);
    border-left: 4px solid var(--electric-blue);
}

.mobile-menu-btn {
    color: #fff;
    padding: .5rem;
    border-radius: .375rem;
    transition: background-color .2s;
}
.mobile-menu-btn:hover,
.mobile-menu-btn:focus {
    background-color: rgba(255,255,255,.1);
}

.mobile-menu {
    /* visibility controlled via .hidden utility class */
    background-color: rgba(10,12,16,1);
    border-top: 1px solid rgba(255,255,255,.05);
}

/* button base and variants */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    font-weight: 700;
    transition: all .2s;
    cursor: pointer;
    border: none;
    text-decoration: none;
}

.btn[class*="w-full"],
.btn.w-full {
    display: flex;
    width: 100%;
}

.btn-primary {
    background: linear-gradient(to right, var(--cyan-500), var(--blue-600));
    color: #fff;
    padding: .75rem 2rem;
    border-radius: 9999px;
    font-size: 1rem;
    box-shadow: 0 10px 15px var(--shadow-blue-20);
}
.btn-primary:hover {
    box-shadow: 0 10px 15px var(--shadow-blue-40);
    transform: translateY(-.25rem) scale(1.02);
}

.text-gradient {
    background: linear-gradient(to right, var(--cyan-400), var(--cyan-500), var(--blue-500), var(--electric-blue));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: brightness(1.3);
}

.text-muted {
    color: var(--metallic-silver) !important;
}

.btn-secondary {
    background-color: rgba(0,0,0,.4);
    backdrop-filter: blur(12px);
    color: #fff;
    border: 1px solid rgba(255,255,255,.2);
    padding: .75rem 2rem;
    border-radius: 9999px;
    font-size: 1rem;
}
.btn-secondary:hover {
    background-color: rgba(0,0,0,.6);
}

.btn-outline {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    color: #fff;
    font-weight: 700;
    font-size: .875rem;
    background-color: rgba(255,255,255,.05);
    padding: .5rem 1rem;
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,.1);
    transition: background-color .2s;
}
.btn-outline:hover {
    background-color: rgba(255,255,255,.1);
}

/* form controls */
.form-input,
.form-select,
.form-textarea {
    width: 100%;
    background-color: #0F1115;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 1rem;
    padding: .75rem;
    color: #fff;
    transition: all .2s;
    font-size: .875rem;
    outline: none;
}
.form-input:focus,
.form-select:focus,
.form-textarea:focus {
    box-shadow: 0 0 0 2px var(--electric-blue);
    border-color: transparent;
}
.form-input::placeholder,
.form-select::placeholder,
.form-textarea::placeholder {
    color: rgba(255,255,255,.2);
}

.form-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--metallic-silver);
    text-transform: uppercase;
    letter-spacing: .05em;
    padding-left: .25rem;
}

/* hero section helpers */
.hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 8rem;
    padding-bottom: 5rem;
    overflow: hidden;
    min-height: 100vh;
}
.hero .content {
    position: relative;
    z-index: 20;
    text-align: center;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.hero .badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .5rem 1rem;
    border-radius: 9999px;
    background-color: rgba(0,0,0,.4);
    border: 1px solid rgba(255,255,255,.2);
    color: var(--metallic-silver);
    font-size: .625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .25em;
    box-shadow: 0 10px 15px rgba(0,0,0,.5);
    margin-bottom: 1.5rem;
}
.hero h1 {
    font-size: 2.25rem;
    line-height: 1.05;
    font-weight: 800;
    color: #fff;
    margin-bottom: 1.5rem;
}
@media (min-width: 768px) {
    .hero h1 { font-size: 3.75rem; }
}
@media (min-width: 1024px) {
    .hero h1 { font-size: 4.5rem; }
}
.hero .description {
    font-size: 1rem;
    color: #fff;
    max-width: 48rem;
    font-weight: 400;
    line-height: 1.625;
    margin-bottom: 2.5rem;
    text-shadow: 0 2px 2px rgba(0,0,0,0.8);
}
@media (min-width: 768px) {
    .hero .description { font-size: 1.25rem; }
}

.cta-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
    width: 100%;
}
@media (min-width: 640px) {
    .cta-group {
        flex-direction: row;
        width: auto;
    }
}

/* generic card */
.card {
    padding: 2rem;
    border-radius: 1.875rem;
    background-color: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.05);
    transition: all .3s;
    cursor: default;
}
.card:hover {
    transform: translateY(-.5rem);
    box-shadow: 0 15px 30px var(--shadow-blue-20);
}

/* specialized card for services grid */
.service-card {
    padding: 2rem;
    border-radius: 1.875rem;
    background-color: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.05);
    transition: all .3s;
    cursor: default;
    height: 100%;
}
.service-card:hover {
    border-color: rgba(46,144,250,.3);
    transform: translateY(-.5rem);
    box-shadow: 0 25px 50px var(--shadow-blue-20);
}
.service-card .icon {
    display: block;
    margin-bottom: 1.5rem;
    color: var(--electric-blue);
    font-size: 2rem;
    transition: transform .3s;
}
.service-card:hover .icon {
    transform: scale(1.1);
}

.section {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-top: 5rem;
    padding-bottom: 5rem;
}
@media (min-width: 1024px) {
    .section {
        padding-top: 7rem;
        padding-bottom: 7rem;
    }
}

.section-services {
    border-top: 1px solid rgba(255,255,255,.05);
    border-bottom: 1px solid rgba(255,255,255,.05);
}

.services-list {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    list-style: none;
}
@media (min-width: 768px) {
    .services-list {
        grid-template-columns: repeat(3, 1fr);
    }
}

.steps-grid {
    display: grid;
    grid-template-columns: repeat(1,1fr);
    gap: 1.5rem;
    list-style: none;
}
@media (min-width: 768px) {
    .steps-grid {
        grid-template-columns: repeat(2,1fr);
    }
}
@media (min-width: 1024px) {
    .steps-grid {
        grid-template-columns: repeat(4,1fr);
        gap: 2rem;
    }
}

.properties-grid {
    display: grid;
    grid-template-columns: repeat(1,1fr);
    gap: 2rem;
    list-style: none;
}
@media (min-width: 768px) {
    .properties-grid {
        grid-template-columns: repeat(2,1fr);
    }
}
@media (min-width: 1024px) {
    .properties-grid {
        grid-template-columns: repeat(3,1fr);
    }
}

.property-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    aspect-ratio: 4 / 5;
    border-radius: 2rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.1);
    background-color: rgba(255,255,255,.05);
    padding: 2rem;
    text-align: center;
    backdrop-filter: blur(12px);
    box-shadow: 0 25px 50px var(--shadow-blue-20);
    transition: all .5s;
}
.property-card:hover {
    box-shadow: 0 25px 50px var(--shadow-blue-20);
    border-color: rgba(46,144,250,.3);
}
.property-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: .5;
    filter: grayscale(100%);
    transition: all .7s;
}
.property-card:hover img {
    opacity: .3;
    filter: grayscale(0);
    transform: scale(1.1);
}
.property-card .overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0,0,0,.5);
    transition: background-color .5s;
}
.property-card:hover .overlay {
    background-color: rgba(0,0,0,.3);
}
.property-card .content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
}

/* additional helpers can be added as needed */

.trust-indicators {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    border-top: 1px solid rgba(255,255,255,.2);
    padding-top: 2rem;
    width: 100%;
    backdrop-filter: blur(20px);
    background-color: rgba(0,0,0,.3);
    border-radius: 1.25rem;
    padding-bottom: 1.5rem;
    box-shadow: 0 25px 50px var(--shadow-blue-20);
}

.trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
    padding: .5rem;
    cursor: default;
}

.trust-item .icon {
    transition: transform .3s;
}
.trust-item:hover .icon {
    transform: scale(1.1);
}

.logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    transition: opacity .2s;
}
.logo:hover {
    opacity: .8;
}
.logo .brand {
    font-weight: 800;
    font-size: 2rem;
    letter-spacing: -.025em;
    text-transform: uppercase;
    font-style: italic;
    color: #fff;
    line-height: 1;
}
.logo .brand .highlight {
    color: var(--electric-blue);
}
.logo .tagline {
    font-size: 8px;
    font-weight: 700;
    color: var(--metallic-silver);
    letter-spacing: .25em;
    text-transform: uppercase;
    margin-top: .25rem;
    transition: color .2s;
}
.logo:hover .tagline {
    color: #fff;
}

/* ===========================================
   SEMANTIC COMPONENT CLASSES
   =========================================== */

/* Section Titles - Large responsive headings */
.section-title {
    font-size: 1.875rem;
    font-weight: 800;
    color: var(--text-main);
    margin-bottom: 1.5rem;
    letter-spacing: -0.025em;
}

@media (min-width: 768px) {
    .section-title {
        font-size: 2.25rem;
    }
}

@media (min-width: 1024px) {
    .section-title {
        font-size: 3rem;
    }
}

/* Card Titles - Medium heading for cards */
.card-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 0.75rem;
}

/* Section Description - Standard paragraph styling */
.section-description {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.5;
}

@media (min-width: 768px) {
    .section-description {
        font-size: 1.125rem;
    }
}

/* Trust Label - Small uppercase accent text */
.trust-label {
    color: var(--text-main);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
}

/* Highlight Accent - Inline highlighted text with bottom border */
.highlight-accent {
    color: var(--text-main);
    font-weight: 700;
    border-bottom: 2px solid var(--vibrant-teal);
    padding-bottom: 0.125rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
}

/* Process Step Card - Base style for process/step cards */
.process-card {
    display: flex;
    flex-direction: column;
    position: relative;
    padding: 2rem;
    border-radius: 1.5rem;
    background-color: rgba(23, 27, 34, 0.8);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s;
}

.process-card:hover {
    transform: translateY(-0.75rem);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
}

/* Process Card Variants - Different border/shadow colors */
.process-card-electric:hover {
    border-color: var(--electric-blue);
    box-shadow: 0 0 30px rgba(46, 144, 250, 0.1);
}

.process-card-teal:hover {
    border-color: var(--vibrant-teal);
    box-shadow: 0 0 30px rgba(21, 225, 208, 0.1);
}

.process-card-purple:hover {
    border-color: var(--purple-500);
    box-shadow: 0 0 30px rgba(168, 85, 247, 0.1);
}

.process-card-white:hover {
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 0 30px rgba(255, 255, 255, 0.05);
}

/* Process Icon Box - Container for step icons */
.process-icon-box {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.5rem;
    background-color: var(--deep-navy);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: border-color 0.3s;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
}

.process-card-electric .process-icon-box:hover {
    border-color: rgba(46, 144, 250, 0.5);
}

.process-card-teal .process-icon-box:hover {
    border-color: rgba(21, 225, 208, 0.5);
}

.process-card-purple .process-icon-box:hover {
    border-color: rgba(168, 85, 247, 0.5);
}

.process-card-white .process-icon-box:hover {
    border-color: rgba(255, 255, 255, 0.3);
}

/* Process Number - Large background number in card corner */
.process-number {
    position: absolute;
    top: -1rem;
    right: -0.5rem;
    font-size: 4.5rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.05);
    transition: color 0.3s;
    user-select: none;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.process-card:hover .process-number {
    color: rgba(255, 255, 255, 0.1);
}

.max-w-3xl {
    max-width: 48rem
}

.max-w-5xl {
    max-width: 64rem
}

.max-w-7xl {
    max-width: 80rem
}

.max-w-lg {
    max-width: 32rem
}

.max-w-none {
    max-width: none
}

.max-w-xs {
    max-width: 20rem
}

.flex-shrink-0,
.shrink-0 {
    flex-shrink: 0
}

.origin-left {
    transform-origin: left
}

/* ===========================================
   TRANSFORMS & ANIMATIONS
   =========================================== */

.transform {
    transform: translate(0, 0) rotate(0deg) skewX(0deg) skewY(0deg) scaleX(1) scaleY(1);
}

@keyframes ping {

    75%,
    to {
        transform: scale(2);
        opacity: 0
    }
}

.animate-ping {
    animation: ping 1s cubic-bezier(0, 0, .2, 1) infinite
}

@keyframes pulse {
    50% {
        opacity: .5
    }
}

.animate-pulse {
    animation: pulse 2s cubic-bezier(.4, 0, .6, 1) infinite
}

/* ===========================================
